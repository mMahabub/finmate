# ============================================================
# FinMate - Environment Variables
# Copy this file to .env.local and fill in your values
# ============================================================

# Database (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth Secrets (generate with: openssl rand -hex 32)
JWT_SECRET=your-jwt-secret-here
NEXTAUTH_SECRET=your-nextauth-secret-here

# App URL (your Render deployment URL)
NEXTAUTH_URL=https://your-app.onrender.com
NEXT_PUBLIC_APP_URL=https://your-app.onrender.com

# Giphy API (optional - for GIF support in chat)
NEXT_PUBLIC_GIPHY_API_KEY=your-giphy-api-key

# Google Gemini AI (optional - for AI assistant)
GEMINI_API_KEY=your-gemini-api-key

# TURN Server (optional - for WebRTC calls across NAT/firewalls)
# Get free credentials at https://www.metered.ca/tools/openrelay/
# NEXT_PUBLIC_TURN_URL=turn:a.relay.metered.ca:443?transport=tcp
# NEXT_PUBLIC_TURN_USERNAME=your-username
# NEXT_PUBLIC_TURN_CREDENTIAL=your-credential
